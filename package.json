  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "tsc && vite build",
    "start": "ESLINT_NO_DEV_ERRORS=true vite",
    "firestore:import": "./import_firestore.sh",
    "firebase:emulate": "firebase emulators:start --only hosting,auth,firestore,storage --import=./database",
    "start:dist": "FIREBASE_AUTH_EMULATOR_HOST=\"127.0.0.1:$(cat firebase.json | jq .emulators.auth.port)\" FIRESTORE_EMULATOR_HOST=\"127.0.0.1:$(cat firebase.json | jq .emulators.firestore.port)\" FIREBASE_STORAGE_EMULATOR_HOST=\"127.0.0.1:$(cat firebase.json | jq .emulators.storage.port)\" yarn build && yarn firebase:emulate --log-verbosity SILENT",
    "cy:base": "wait-on http://localhost:3000 && cypress",
    "cy:ci": "run-p -r start:dist 'cy:base run --browser chrome'",
    "cy:local": "SERVICE_ACCOUNT=\"$(cat ./serviceAccount.json)\" run-p -r start:dist 'cy:base run --browser chrome'",
    "cy": "SERVICE_ACCOUNT=\"$(cat ./serviceAccount.json)\" run-p -r start:dist 'cy:base open --e2e --browser chrome'",
    "merge:reports": "mochawesome-merge cypress/reports/*.json > cypress/reports/results.json && rm -rf cypress/reports/cypress-*.json",
    "generate:reports": "marge cypress/reports/results.json -o cypress/reports && node generate-text-report.js",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/base": "^5.0.0-beta.66",
    "@mui/icons-material": "^6.2.0",
    "@mui/material": "^6.2.0",
    "@mui/system": "^6.2.0",
    "@tanstack/react-query": "^5.62.7",
    "firebase": "^11.1.0",
    "lodash": "^4.17.21",
    "react": "^19.0.0",
    "react-card-flip": "^1.2.3",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^7.0.2",
    "react-swipeable": "^7.0.2",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@types/lodash": "4.17.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "c8": "^10.1.3",
    "cypress": "^15.5.0",
    "cypress-firebase": "^4.2.2",
    "cypress-mochawesome-reporter": "^3.2.3",
    "eslint": "^9.16.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-vitest": "^0.5.4",
    "firebase-admin": "^13.0.1",
    "jsdom": "^25.0.1",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.2.0",
    "npm-run-all": "^4.1.5",
    "vite": "^6.0.3",
    "vite-plugin-svgr": "^4.3.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
