{
  "name": "dnd5",
  "license": "MIT",
  "author": {
    "name": "Alison Prouteau",
    "email": "alison.prouteau@gmail.com"
  },
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "prepare": "husky",
    "format": "yarn prettier --write 'src/**/*.{ts,tsx}'",
    "build": "tsc && vite build",
    "start": "ESLINT_NO_DEV_ERRORS=true vite",
    "firestore:import": "./import_firestore.sh",
    "firebase:emulate": "firebase emulators:start --only hosting,auth,firestore,storage --import=./database",
    "start:dist": "FIREBASE_AUTH_EMULATOR_HOST=\"127.0.0.1:$(cat firebase.json | jq .emulators.auth.port)\" FIRESTORE_EMULATOR_HOST=\"127.0.0.1:$(cat firebase.json | jq .emulators.firestore.port)\" FIREBASE_STORAGE_EMULATOR_HOST=\"127.0.0.1:$(cat firebase.json | jq .emulators.storage.port)\" yarn build && yarn firebase:emulate --log-verbosity SILENT",
    "cy:base": "wait-on http://127.0.0.1:3000 && cypress",
    "cy:local": "SERVICE_ACCOUNT=\"$(cat ./serviceAccount.json)\" run-p -r start:dist 'cy:base run --browser chrome'",
    "cy": "SERVICE_ACCOUNT=\"$(cat ./serviceAccount.json)\" run-p -r start:dist 'cy:base open --e2e --browser chrome'",
    "merge:reports": "mochawesome-merge cypress/reports/*.json > cypress/reports/results.json && rm -rf cypress/reports/cypress-*.json",
    "generate:reports": "marge cypress/reports/results.json -o cypress/reports && node generate-text-report.js",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/base": "^5.0.0-beta.70",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.6",
    "@mui/system": "^7.3.6",
    "@tanstack/react-query": "^5.90.12",
    "firebase": "^12.6.0",
    "lodash": "^4.17.21",
    "react": "^19.2.3",
    "react-card-flip": "^1.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.71.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.10.1",
    "react-swipeable": "^7.0.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/lodash": "4.17.21",
    "@types/node": "^25.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.15",
    "c8": "^10.1.3",
    "cypress": "^15.7.1",
    "cypress-firebase": "^4.2.2",
    "cypress-mochawesome-reporter": "^4.0.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-vitest": "^0.5.4",
    "firebase-admin": "^13.6.0",
    "glob": "^10.3.3",
    "husky": "^9.1.7",
    "jsdom": "^27.3.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^5.1.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.7.4",
    "vite": "^7.2.7",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.15",
    "wait-on": "^9.0.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
