{
  "compilerOptions": {
    "outDir": "./dist/",
    "target": "esnext",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["dom", "dom.iterable", "esnext"],
    "types": ["@emotion/react", "vitest/globals", "vite/client", "vite-plugin-svgr/client"],
    "jsx": "react-jsx",
    "jsxImportSource": "@emotion/react",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@assets": ["src/assets"],
      "@api/*": ["./src/api/*"],
      "@utils/*": ["./src/utils/*"],
      "@representations/*": ["./src/representations/*"],
      "@shared/*": ["./src/components/shared/*"]
    }
  },
  "include": ["src", "vite.config.mts", ".eslintrc.json"],
  "exclude": ["cypress.config.ts", "cypress"]
}
